# ─────────────────────────────────────────────────────────────────────────────
# QA Environment — .env.qa.example
# Copy this file to .env on the QA server and fill in the real values.
#   cp .env.qa.example .env
#
# Rules:
#   • This file IS committed to git — never put real secrets here.
#   • .env is NOT committed to git — real secrets live there only.
#   • When you add a new env var, add it here too so the team knows about it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
NODE_ENV=production
PORT=3020

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb-connection-string-for-qa

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-strong-secret-minimum-32-characters
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-minimum-32-characters

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis-url

# ── CORS & App URLs ───────────────────────────────────────────────────────────
CNAME_TARGET=qa.yourdomain.com
APP_URL=https://qa.yourdomain.com
ALLOWED_ORIGINS=https://qa.yourdomain.com,http://localhost:3000,http://localhost:3020
BASE_URL=https://qa.yourdomain.com
SHORT_DOMAIN=qa.yourdomain.com
BASE_DOMAIN=qa.yourdomain.com
APP_NAME=YourAppName

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100

# ── Cache TTL (seconds) ───────────────────────────────────────────────────────
CACHE_TTL_URL_CACHE=3600
CACHE_TTL_DOMAIN_CACHE=300

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=port-number-for-smtp
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-smtp-app-password
SUPPORT_EMAIL=support@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_with_real_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret

# ── Google Analytics ──────────────────────────────────────────────────────────
GA_PROPERTY_ID=your-ga-property-id
GA_CREDENTIALS_PATH=./src/config/ga-credentials.json

# ── Amplitude ─────────────────────────────────────────────────────────────────
AMPLITUDE_API_KEY=your-amplitude-api-key

# ── Google Safe Browsing ──────────────────────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key

# ── IPInfo ────────────────────────────────────────────────────────────────────
# Free token at https://ipinfo.io (50,000 req/month)
IPINFO_TOKEN=your-ipinfo-token

# ── SSL Provisioning ──────────────────────────────────────────────────────────
# Email Let's Encrypt uses to send expiry warnings — use one you actually monitor.
SSL_ADMIN_EMAIL=admin@yourdomain.com

# certbot needs root; ecs-user has NOPASSWD sudo so this works without a password prompt.
SSL_USE_SUDO=true

# certbot writes ACME challenge tokens here.
# Your nginx container mounts this path → /var/www/certbot (rw).
CERTBOT_WEBROOT=/opt/your-platform/certbot-webroot

# Path used INSIDE generated nginx config text — this is the container-internal path
# that nginx sees for SSL certs (volume: /opt/your-platform/nginx/ssl → /etc/nginx/ssl).
NGINX_SSL_DIR=/etc/nginx/ssl

# Host path where cert files are physically written by the Node process.
# Nginx reads these via the volume mount above.
NGINX_SSL_WRITE_DIR=/opt/your-platform/nginx/ssl

# Host paths for per-domain nginx config files.
# Nginx mounts sites-enabled read-only — Node writes here, nginx reads it.
NGINX_SITES_AVAILABLE=/opt/your-platform/nginx/sites-available
NGINX_SITES_ENABLED=/opt/your-platform/nginx/sites-enabled

# Name of the running nginx Docker container.
# Used to run: docker exec <container-name> nginx -s reload
NGINX_CONTAINER_NAME=your-nginx-container

# Comma-separated list of domains whose nginx configs must never be auto-deleted.
PROTECTED_DOMAINS=qa.yourdomain.com,www.qa.yourdomain.com

# URL Scanner (src/services/urlScanner/) — moderation pipeline
ANTHROPIC_API_KEY=anthropic-api-key
FIRECRAWL_API_KEY=firecrawl-api-key
SAFEBROWZ_API_KEY=safebrowz-api-key

# IPQualityScore — not currently wired into any service (no code references IPQS_API_KEY yet)
IPQS_API_KEY=ipqualityscore-api-key

